OPENAI_BASE_URL=https://api.xinqing.xyz/v1
OPENAI_MODEL=gpt-5.4

ANTHROPIC_API_KEY=sk-356b95cddae729e51c6a90304dee7956b6faac05236c50bcd7c3072c0ff400b9
ANTHROPIC_MODEL=gpt-5.3-codex
ANTHROPIC_BASE_URL=https://api.xinqing.xyz/v1
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
DATABASE_URL=sqlite:///./openclaw.db

# JWT Auth
# ⚠️ 生产环境必须设为 true，开发期间前端未接入认证时可设为 false
AUTH_ENABLED=false

# OAuth — Google Login
# 1. 前往 https://console.cloud.google.com/apis/credentials
# 2. 创建 OAuth 2.0 客户端 ID，类型选 "Web 应用"
# 3. 在"已获授权的重定向 URI"中添加: http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_ENABLED=false

# App base URL — OAuth redirect_uri 的前缀 (Vite 开发服务器地址)
# 生产环境改为实际域名, 如 https://app.example.com
APP_BASE_URL=http://localhost:3000
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

LOG_LEVEL=INFO
MAX_SHORT_TERM_MEMORY=10
AGENT_CONCURRENCY=1
ITINERARY_DAY_CONCURRENCY=2

# SerpAPI — Google Flights & Hotels real data
SERPAPI_KEY=916f12f47b10f7b4b63b306ab484ad725e840587ac2904f217fb9f32db1bae6d
SERPAPI_ENABLED=true

